# NAME: Telegram
# AUTHOR: steak
# TYPE: Quantumult X Filter
# DESCRIPTION: Telegram / Telegram X / Telegram Desktop / Telegram Web / 第三方 Telegram 客户端相关分流规则
# SOURCE: Based on blackmatrix7/ios_rule_script Telegram rules
# UPDATED: 2026-05-11
#
# ================================
# 使用说明
# ================================
# 1. 文件名建议：Telegram.list
# 2. 适用于：Quantumult X [filter_remote]
# 3. 策略组名称：Telegram
# 4. 如果你的策略组不是 Telegram，请在 QX 的 force-policy 中指定实际策略组
# 5. IP-CIDR / IP6-CIDR 后加入 no-resolve，避免触发不必要 DNS 解析
#
# QX 远程订阅示例：
# https://raw.githubusercontent.com/你的用户名/你的仓库/main/Rules/Telegram.list, tag=Telegram, force-policy=Telegram, update-interval=86400, opt-parser=false, enabled=true
#
# ================================
# 规则统计
# ================================
# HOST: 2
# HOST-KEYWORD: 1
# HOST-SUFFIX: 22
# IP-CIDR: 6
# IP6-CIDR: 4
# IP-ASN: 5
# TOTAL: 40
#
# ================================
# Telegram API / 第三方客户端
# ================================

HOST,api.imem.app,Telegram
HOST,api.swiftgram.app,Telegram

# ================================
# Telegram 域名规则
# ================================

HOST-SUFFIX,cdn-telegram.org,Telegram
HOST-SUFFIX,comments.app,Telegram
HOST-SUFFIX,contest.com,Telegram
HOST-SUFFIX,graph.org,Telegram
HOST-SUFFIX,legra.ph,Telegram
HOST-SUFFIX,mbrx.app,Telegram
HOST-SUFFIX,quiz.directory,Telegram
HOST-SUFFIX,stel.com,Telegram
HOST-SUFFIX,t.me,Telegram
HOST-SUFFIX,tdesktop.com,Telegram
HOST-SUFFIX,telega.one,Telegram
HOST-SUFFIX,telegra.ph,Telegram
HOST-SUFFIX,telegram-cdn.org,Telegram
HOST-SUFFIX,telegram.dog,Telegram
HOST-SUFFIX,telegram.me,Telegram
HOST-SUFFIX,telegram.org,Telegram
HOST-SUFFIX,telegram.space,Telegram
HOST-SUFFIX,telegramdownload.com,Telegram
HOST-SUFFIX,telesco.pe,Telegram
HOST-SUFFIX,tg.dev,Telegram
HOST-SUFFIX,tx.me,Telegram
HOST-SUFFIX,usercontent.dev,Telegram

# ================================
# Telegram 第三方客户端关键词
# ================================

HOST-KEYWORD,nicegram,Telegram

# ================================
# Telegram IPv4 段
# ================================
# no-resolve：IP 规则无需 DNS 解析，减少误解析和延迟

IP-CIDR,109.239.140.0/24,Telegram,no-resolve
IP-CIDR,139.59.210.98/32,Telegram,no-resolve
IP-CIDR,149.154.160.0/20,Telegram,no-resolve
IP-CIDR,196.55.216.167/32,Telegram,no-resolve
IP-CIDR,5.28.192.0/18,Telegram,no-resolve
IP-CIDR,91.108.0.0/16,Telegram,no-resolve

# ================================
# Telegram IPv6 段
# ================================

IP6-CIDR,2001:67c:4e8::/48,Telegram,no-resolve
IP6-CIDR,2001:b28:f23c::/47,Telegram,no-resolve
IP6-CIDR,2001:b28:f23f::/48,Telegram,no-resolve
IP6-CIDR,2a0a:f280::/29,Telegram,no-resolve

# ================================
# Telegram ASN
# ================================
# ASN 规则用于匹配 Telegram 相关自治系统网络

IP-ASN,211157,Telegram
IP-ASN,44907,Telegram
IP-ASN,59930,Telegram
IP-ASN,62014,Telegram
IP-ASN,62041,Telegram
