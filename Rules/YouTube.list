# NAME: YouTube
# AUTHOR: steak
# TYPE: Quantumult X Filter
# DESCRIPTION: YouTube / YouTube Music / YouTube Kids / Googlevideo / ytimg 相关分流规则
# SOURCE: Based on blackmatrix7/ios_rule_script YouTube rules
# UPDATED: 2026-05-11
#
# ================================
# 使用说明
# ================================
# 1. 文件名建议：YouTube.list
# 2. 适用于：Quantumult X [filter_remote]
# 3. 策略组名称：YouTube
# 4. 如果你的策略组不是 YouTube，请在 QX 的 force-policy 中指定实际策略组
# 5. 不建议把整个 googleapis.com / googleusercontent.com / gstatic.com 全部放进 YouTube
#    否则可能会影响 Gemini / Google AI / Google 登录 / Google 其他服务
#
# QX 远程订阅示例：
# https://raw.githubusercontent.com/你的用户名/你的仓库/main/Rules/YouTube.list, tag=YouTube, force-policy=YouTube, update-interval=86400, opt-parser=false, enabled=true
#
# ================================
# 规则统计：精简增强版
# ================================
# HOST: 3
# HOST-SUFFIX: 37
# HOST-WILDCARD: 3
# HOST-KEYWORD: 2
# USER-AGENT: 7
# IP-CIDR: 2
# IP6-CIDR: 1
#
# ================================
# YouTube 精确域名
# ================================

HOST,music.youtube.com,YouTube
HOST,youtubei.googleapis.com,YouTube
HOST,yt3.ggpht.com,YouTube

# ================================
# YouTube 核心域名
# ================================

HOST-SUFFIX,youtube.com,YouTube
HOST-SUFFIX,youtu.be,YouTube
HOST-SUFFIX,yt.be,YouTube
HOST-SUFFIX,ytimg.com,YouTube
HOST-SUFFIX,googlevideo.com,YouTube
HOST-SUFFIX,youtube-nocookie.com,YouTube
HOST-SUFFIX,withyoutube.com,YouTube
HOST-SUFFIX,ggpht.com,YouTube
HOST-SUFFIX,ggpht.cn,YouTube
HOST-SUFFIX,gvt1.com,YouTube
HOST-SUFFIX,gvt2.com,YouTube
HOST-SUFFIX,video.google.com,YouTube

# ================================
# YouTube API / 嵌入 / 播放器
# ================================

HOST-SUFFIX,youtube.googleapis.com,YouTube
HOST-SUFFIX,youtubei.googleapis.com,YouTube
HOST-SUFFIX,youtubeembeddedplayer.googleapis.com,YouTube
HOST-SUFFIX,youtube-ui.l.google.com,YouTube
HOST-SUFFIX,wide-youtube.l.google.com,YouTube

# ================================
# YouTube 衍生服务
# ================================

HOST-SUFFIX,youtubekids.com,YouTube
HOST-SUFFIX,youtubegaming.com,YouTube
HOST-SUFFIX,youtubemobilesupport.com,YouTube
HOST-SUFFIX,youtubeeducation.com,YouTube
HOST-SUFFIX,youtubefanfest.com,YouTube

# ================================
# YouTube Go
# ================================

HOST-SUFFIX,youtubego.com,YouTube
HOST-SUFFIX,youtubego.co.id,YouTube
HOST-SUFFIX,youtubego.co.in,YouTube
HOST-SUFFIX,youtubego.com.br,YouTube
HOST-SUFFIX,youtubego.id,YouTube
HOST-SUFFIX,youtubego.in,YouTube

# ================================
# YouTube 国际化域名补充
# ================================
# blackmatrix7 原规则中包含大量 youtube.xx / youtube.com.xx 地区域名
# 这里用 HOST-WILDCARD 收敛处理，减少规则数量

HOST-SUFFIX,youtube,YouTube
HOST-WILDCARD,youtube.*,YouTube
HOST-WILDCARD,youtube.*.*,YouTube
HOST-WILDCARD,youtube.com.*,YouTube

# ================================
# YouTube 关键词
# ================================

HOST-KEYWORD,youtube,YouTube
HOST-KEYWORD,googlevideo,YouTube

# ================================
# YouTube App / YouTube Music UA
# ================================

USER-AGENT,*YouTubeMusic*,YouTube
USER-AGENT,*com.google.ios.youtubemusic*,YouTube
USER-AGENT,*youtube*,YouTube
USER-AGENT,YouTube*,YouTube
USER-AGENT,YouTubeMusic*,YouTube
USER-AGENT,com.google.ios.youtube*,YouTube
USER-AGENT,com.google.ios.youtubemusic*,YouTube

# ================================
# YouTube IP 段
# ================================
# no-resolve：IP 规则无需 DNS 解析，减少误解析和延迟

IP-CIDR,172.110.32.0/21,YouTube,no-resolve
IP-CIDR,216.73.80.0/20,YouTube,no-resolve
IP6-CIDR,2620:120:e000::/40,YouTube,no-resolve

# ================================
# 不建议启用的宽泛 Google 规则
# ================================
# 以下规则可能会误伤 Gemini / Google AI / Google 登录 / Google Drive / Google API
# 如无特殊需求，不建议取消注释
#
# HOST-SUFFIX,googleapis.com,YouTube
# HOST-SUFFIX,googleusercontent.com,YouTube
# HOST-SUFFIX,gstatic.com,YouTube
