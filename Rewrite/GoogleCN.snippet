# Google 自动中文跳转
# 功能：
# 1. g.cn / google.cn 跳转到 google.com
# 2. google.com 自动加 hl=zh-CN
# 3. maps.google.cn 跳转到 maps.google.com 并加中文参数

hostname = g.cn, google.cn, www.google.cn, google.com, www.google.com, maps.google.com, maps.google.cn, ditu.google.cn

^https?:\/\/(?:www\.)?(?:g|google)\.cn(?:\/.*)?$ url script-echo-response https://raw.githubusercontent.com/reverie1988/QX/main/Scripts/Google_Chinese_Redirect.js
^https?:\/\/(?:ditu|maps)\.google\.cn(?:\/.*)?$ url script-echo-response https://raw.githubusercontent.com/reverie1988/QX/main/Scripts/Google_Chinese_Redirect.js

^https?:\/\/(?:www\.)?google\.com(?!.*[?&]hl=zh-CN)(?:\/.*)?$ url script-echo-response https://raw.githubusercontent.com/reverie1988/QX/main/Scripts/Google_Chinese_Redirect.js
^https?:\/\/maps\.google\.com(?!.*[?&]hl=zh-CN)(?:\/.*)?$ url script-echo-response https://raw.githubusercontent.com/reverie1988/QX/main/Scripts/Google_Chinese_Redirect.js